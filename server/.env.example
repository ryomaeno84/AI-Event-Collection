# Upload authentication key (shared with performers)
UPLOAD_KEY=1111

# Path to Google Drive service account credentials JSON file
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Google Drive folder IDs per event
FOLDER_ID_SPRING=dummy_folder_id_event_a
FOLDER_ID_SUMMER=dummy_folder_id_event_b
FOLDER_ID_AUTUMN=dummy_folder_id_event_c
FOLDER_ID_KOHAKU=dummy_folder_id_event_d

# Email notification settings (Gmail)
EMAIL_USER=dummy@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# Server port
PORT=3000
